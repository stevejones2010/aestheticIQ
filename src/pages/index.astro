---
import BaseLayout from '@layouts/BaseLayout.astro';
import Hero from '@components/Hero.astro';
import SectionHeader from '@components/SectionHeader.astro';
import IndustryCard from '@components/IndustryCard.astro';
import { getCollection } from 'astro:content';

// ============================================================
// PAGE DATA — all the homepage content lives here
// ============================================================

const pageStats = [
  { num: '15,000+', label: 'UK clinic records' },
  { num: '50,000+', label: 'Live prices monitored' },
  { num: '100+', label: 'Brand signals tracked' },
  { num: '28', label: 'Treatment categories' },
];

const volumeStats = [
  { num: '50+', label: 'Data points per clinic' },
  { num: '15k+', label: 'UK clinic records' },
  { num: '50k+', label: 'Live prices monitored' },
  { num: '100+', label: 'Brands tracked' },
  { num: '28', label: 'Treatment categories' },
];

const dataGapItems = [
  {
    title: 'IQVIA OneKey',
    body: 'The industry standard for HCP data, but focused on GPs, hospitals, and pharmacies. Aesthetic clinics are barely covered.',
  },
  {
    title: 'Fragmented voluntary accreditation',
    body: 'CQC, Save Face, JCCP and other registers each capture a slice. No single source gives a complete picture.',
  },
  {
    title: 'Booking platforms',
    body: 'Consumer-facing data, fragmented across Fresha, Treatwell and others. Not designed for B2B intelligence.',
  },
  {
    title: 'Google Maps & business directories',
    body: 'No treatment-level detail, no practitioner credentials, no pricing, no compliance data.',
  },
  {
    title: 'Manual research',
    body: 'Sales teams spending hours per clinic before every call. Slow, incomplete, and biased toward known accounts.',
  },
];

const workflows = [
  {
    verb: 'Target',
    title: 'Find the right clinics',
    desc: 'Segment the UK aesthetic market by geography, treatment offering, practitioner qualification, brand affiliation, or commercial maturity. Ship prioritised lists straight to your CRM.',
    questions: [
      "Which clinics in my territory use a competitor's toxin?",
      'Where are the white-space opportunities in the South East?',
      "Which clinics haven't heard from my team this year?",
    ],
  },
  {
    verb: 'Track',
    title: 'Monitor the market in motion',
    desc: 'Continuous tracking of pricing, treatment mix, brand adoption and category trends across 15,000 clinics. Spot movement before competitors do.',
    questions: [
      "What's the market share of each toxin brand, by region?",
      'How fast is GLP-1 adoption spreading in UK aesthetics?',
      'Which clinics mention my brand on their website or socials?',
    ],
  },
  {
    verb: 'Verify',
    title: 'Stay compliant, stay confident',
    desc: 'Cross-reference practitioner credentials, licensing status, and regulatory signals. Meet your pharmacovigilance obligations and protect brand integrity under the 2027 licensing regime.',
    questions: [
      'Which practitioners are GMC-registered prescribers?',
      'Which clinics need a premises licence under the new regime?',
      'Are any clinics promoting my product off-label?',
    ],
  },
];

const featuredIndustries = [
  {
    icon: '💉',
    title: 'Pharma & Injectables',
    description:
      'Sales targeting, brand visibility, prescriber verification, and pharmacovigilance for botulinum toxin, dermal fillers, and biostimulators.',
    question: "Which clinics in my territory use my competitor's toxin brand?",
    customers: 'AbbVie/Allergan, Galderma, Merz, Ipsen, Evolus, Teoxane, IBSA',
    href: '/industries/pharma/',
  },
  {
    icon: '🧴',
    title: 'Professional Beauty & Skincare',
    description:
      'Territory planning, account prioritisation, and competitor brand tracking for cosmeceutical skincare sold through clinics.',
    question: "Which clinics are retailing a competitor's professional skincare?",
    customers: 'Obagi, ZO Skin Health, SkinCeuticals, AlumierMD, Mesoestetic, Medik8',
    href: '/industries/beauty-skincare/',
  },
  {
    icon: '📈',
    title: 'Investors & Corporate Finance',
    description:
      'Market sizing, white-space mapping, buy-and-build target lists, and portfolio monitoring for PE, VC, M&A and healthcare lenders.',
    question: 'Which UK regions have the most fragmented clinic ownership?',
    customers: 'PE/VC funds, investment banks, CF boutiques, healthcare lenders',
    href: '/industries/investors/',
  },
];

const questions = [
  "Which clinics in my territory offer my competitor's product?",
  'Where are the white-space opportunities in the South East?',
  'Which practitioners are GMC-registered prescribers for my product?',
  'Which clinics mention my brand on their website or social media?',
  "What's the market share of each toxin brand in London vs Manchester?",
  'Which clinics will need a premises licence under the 2027 regime?',
  "What's the typical treatment mix of a chain acquisition target?",
  'How many UK clinics now offer GLP-1 weight management?',
];

// ============================================================
// PULL LATEST INSIGHTS from content collection
// ============================================================
let latestInsights: any[] = [];
try {
  const allInsights = await getCollection('insights', ({ data }) => !data.draft);
  latestInsights = allInsights
    .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
    .slice(0, 3);
} catch (e) {
  // No insights yet — fall back to placeholder data shown below
  latestInsights = [];
}

// Fallback placeholders if no insights have been written yet
const placeholderInsights = [
  {
    slug: 'glp1-h1-2026',
    data: {
      category: 'Market data',
      title: 'GLP-1 adoption in UK aesthetics — H1 2026',
      excerpt:
        '22% of London skin clinics now offer Wegovy, Mounjaro, or Ozempic. The trajectory, the regional pattern, and the implications for injectable pharma.',
      date: new Date('2026-04-22'),
      readTime: '7 min read',
    },
  },
  {
    slug: 'licensing-2027',
    data: {
      category: 'Regulatory',
      title: 'The UK licensing regime: 2027 readiness report',
      excerpt:
        'What the amber and green tiers mean for 15,000 UK clinics. Regional rollout timeline and estimated impact on supplier sales motion.',
      date: new Date('2026-04-15'),
      readTime: '11 min read',
    },
  },
  {
    slug: 'practitioner-verification',
    data: {
      category: 'Methodology',
      title: 'How we verify practitioner credentials',
      excerpt:
        "GMC / NMC cross-referencing, Save Face accreditation, and JCCP registration. Why clinic-level data alone isn't enough.",
      date: new Date('2026-04-08'),
      readTime: '5 min read',
    },
  },
];

const insightsToShow = latestInsights.length > 0 ? latestInsights : placeholderInsights;

const categoryStyles: Record<string, string> = {
  'Market data': 'bg-cyan-500/10 text-cyan-700',
  Regulatory: 'bg-amber-100 text-amber-800',
  Methodology: 'bg-slate-100 text-slate-600',
};

function formatDate(date: Date): string {
  return date.toLocaleDateString('en-GB', { month: 'short', day: 'numeric', year: 'numeric' });
}
---

<BaseLayout
  title="AestheticIQ"
  description="The UK aesthetic clinic intelligence platform. Proprietary clinic data, AI-powered enrichment, and continuous monitoring. Purpose-built for the companies that sell into the UK aesthetic ecosystem."
>
  {/* ==================================================== */}
  {/* SECTION 1 · HERO + STATS RIBBON                       */}
  {/* ==================================================== */}
  <section class="hero-bg pt-24 pb-20">
    <div class="container-site relative z-10">
      <div class="grid lg:grid-cols-[1.1fr_1fr] gap-12 items-center">
        <div>
          <div class="eyebrow-light mb-6">UK AESTHETIC CLINIC INTELLIGENCE</div>
          <h1 class="font-serif text-6xl leading-[1.08] tracking-tighter mb-6 text-white">
            The UK aesthetic clinic intelligence platform.
          </h1>
          <p class="text-[17px] text-white/75 max-w-[680px] leading-relaxed mb-8">
            Proprietary clinic data, AI-powered enrichment, and continuous monitoring. Purpose-built
            for the companies that sell into the UK aesthetic ecosystem.
          </p>
          <div class="flex gap-3 flex-wrap">
            <a href="/contact/" class="btn-primary">Book a demo →</a>
            <a href="/platform/" class="btn-secondary-light">Explore the platform</a>
          </div>
        </div>

        {/* Floating data cards on the right */}
        <div class="hidden lg:flex flex-col gap-3 relative">
          <div class="bg-white/[0.04] backdrop-blur-sm border border-white/10 rounded-card p-5 self-start max-w-[280px]">
            <div class="text-[10px] uppercase tracking-eyebrow text-white/55 mb-1.5">
              LONDON · SKIN CLINICS
            </div>
            <div class="font-serif text-3xl text-white leading-none">
              458 <span class="text-base text-cyan-500">clinics</span>
            </div>
            <div class="text-[11px] text-white/55 mt-1.5">Treatment-verified, geocoded</div>
          </div>

          <div class="bg-white/[0.04] backdrop-blur-sm border border-white/10 rounded-card p-5 self-end max-w-[280px]">
            <div class="text-[10px] uppercase tracking-eyebrow text-white/55 mb-1.5">
              BRAND SIGNAL · PROFHILO
            </div>
            <div class="font-serif text-3xl text-white leading-none">23.4%</div>
            <div class="text-[11px] text-white/55 mt-1.5">of clinics mention brand on website</div>
          </div>

          <div class="bg-white/[0.04] backdrop-blur-sm border border-white/10 rounded-card p-5 self-start max-w-[280px]">
            <div class="text-[10px] uppercase tracking-eyebrow text-white/55 mb-1.5">
              LIP FILLER · 1ML · LONDON
            </div>
            <div class="font-serif text-3xl leading-none text-cyan-500">
              £280<span class="text-base text-white/50">–340</span>
            </div>
            <div class="text-[11px] text-white/55 mt-1.5">Median · live-tracked</div>
          </div>
        </div>
      </div>
    </div>
  </section>

  {/* Stats ribbon between hero and volume */}
  <section class="bg-navy-900 border-t border-white/8 py-7">
    <div class="container-site">
      <div class="grid grid-cols-2 md:grid-cols-4 gap-6">
        {pageStats.map((stat) => (
          <div class="text-center md:text-left border-l-0 md:first:border-l md:border-l border-white/8 md:pl-6">
            <div class="font-serif text-2xl text-cyan-500 leading-none">{stat.num}</div>
            <div class="text-[11px] text-white/55 uppercase tracking-eyebrow mt-1.5">
              {stat.label}
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  {/* ==================================================== */}
  {/* SECTION 2 · VOLUME STATEMENT                          */}
  {/* ==================================================== */}
  <section class="section">
    <div class="container-tight text-center">
      <div class="eyebrow mb-4">SCALE AND DEPTH</div>
      <h2 class="font-serif text-3xl md:text-4xl text-navy-900 leading-tight tracking-tighter mb-10">
        A continuous stream of market intelligence, built from
        <em class="text-cyan-500 not-italic">dozens of live trackers</em>, augmented with public
        records, and verified directly by clinic owners themselves.
      </h2>

      <div class="grid grid-cols-2 md:grid-cols-5 gap-3 mb-8">
        {volumeStats.map((stat) => (
          <div class="bg-slate-50 border border-slate-200 rounded-card p-5 text-center">
            <div class="font-serif text-2xl text-navy-900 leading-none">{stat.num}</div>
            <div class="text-[11px] text-slate-500 uppercase tracking-eyebrow mt-1.5">
              {stat.label}
            </div>
          </div>
        ))}
      </div>

      <p class="text-[13px] text-slate-500 max-w-[640px] mx-auto leading-relaxed">
        Every record is assembled from <strong class="text-navy-900 font-medium">multiple
        independent sources</strong>. Continuously updated, cross-validated, and audit-traced.
        The dataset grows deeper every day.
      </p>
    </div>
  </section>

  {/* ==================================================== */}
  {/* SECTION 3 · THE DATA GAP                              */}
  {/* ==================================================== */}
  <section class="section-alt">
    <div class="container-site">
      <div class="grid lg:grid-cols-[1fr_1.2fr] gap-12">
        <div>
          <div class="eyebrow mb-4">THE DATA GAP</div>
          <h2 class="display-title mb-5">
            The UK has 25,000 aesthetic providers. Nobody has a complete view.
          </h2>
          <p class="text-lg text-slate-600 leading-relaxed mb-4">
            Existing data sources cover fragments of the market. Most B2B sales teams rely on
            partial CRM data, generic business directories, and manual research before every call.
            The result: missed opportunities, wasted pipeline, and compliance blind spots.
          </p>
          <p class="text-lg text-slate-600 leading-relaxed">
            AestheticIQ is the first platform purpose-built for this market.
          </p>
        </div>

        <div class="flex flex-col gap-3">
          {dataGapItems.map((item) => (
            <div class="bg-white border border-slate-200 rounded-card p-5">
              <div class="text-sm font-medium text-navy-900 mb-1.5">{item.title}</div>
              <div class="text-[12.5px] text-slate-600 leading-relaxed">{item.body}</div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  {/* ==================================================== */}
  {/* SECTION 4 · PLATFORM WORKFLOWS                        */}
  {/* ==================================================== */}
  <section class="section">
    <div class="container-site">
      <SectionHeader
        eyebrow="THE PLATFORM"
        title="Three workflows. One dataset. Every decision in UK aesthetics."
        subtitle="Commercial, regulatory, and investment teams use AestheticIQ to answer the questions that move the needle, without the weeks of manual research it would otherwise take."
        centered
      />

      <div class="grid md:grid-cols-3 gap-5">
        {workflows.map((wf) => (
          <div class="bg-white border border-slate-200 rounded-card p-7 hover:border-cyan-500 hover:shadow-card-strong transition-all duration-200">
            <div class="text-[10px] tracking-eyebrow uppercase text-cyan-500 font-medium mb-2">
              {wf.verb}
            </div>
            <h3 class="font-serif text-2xl text-navy-900 mb-3 leading-tight">{wf.title}</h3>
            <p class="text-[13.5px] text-slate-600 leading-relaxed mb-5">{wf.desc}</p>

            <div class="pt-4 border-t border-slate-100">
              <div class="text-[9px] tracking-eyebrow uppercase text-slate-500 font-medium mb-3">
                ANSWERS QUESTIONS LIKE
              </div>
              <div class="flex flex-col gap-2">
                {wf.questions.map((q) => (
                  <div class="text-[12px] text-slate-700 bg-slate-50 rounded-md px-3 py-2 leading-relaxed">
                    {q}
                  </div>
                ))}
              </div>
            </div>
          </div>
        ))}
      </div>

      <div class="text-center mt-10">
        <a href="/platform/" class="text-[13.5px] text-cyan-500 font-medium hover:text-cyan-600">
          Explore the platform in depth →
        </a>
      </div>
    </div>
  </section>

  {/* ==================================================== */}
  {/* SECTION 5 · INDUSTRIES (3 PRIORITY)                   */}
  {/* ==================================================== */}
  <section class="section-alt">
    <div class="container-site">
      <SectionHeader
        eyebrow="WHO WE SERVE"
        title="Built for the companies that sell into UK aesthetics."
        subtitle="One dataset, tailored to how each industry buys, targets, and measures success."
        centered
      />

      <div class="grid md:grid-cols-3 gap-5 mb-8">
        {featuredIndustries.map((industry) => (
          <a
            href={industry.href}
            class="bg-white border border-slate-200 rounded-card p-7 hover:border-cyan-500 hover:shadow-card-strong hover:-translate-y-1 transition-all duration-200 flex flex-col"
          >
            <div class="text-3xl mb-4">{industry.icon}</div>
            <h3 class="font-serif text-xl text-navy-900 mb-3 leading-tight">{industry.title}</h3>
            <p class="text-[13px] text-slate-600 leading-relaxed mb-4 flex-1">
              {industry.description}
            </p>

            <div class="bg-cyan-500/5 border-l-2 border-cyan-500 rounded-r-md p-3 mb-4">
              <div class="text-[12px] text-navy-900 leading-relaxed italic">
                "{industry.question}"
              </div>
            </div>

            <div class="text-[11.5px] text-slate-500 leading-relaxed mb-3">
              <strong class="text-navy-900 font-medium">Typical customer:</strong>{' '}
              {industry.customers}
            </div>

            <div class="text-[12.5px] text-cyan-500 font-medium mt-auto">Explore →</div>
          </a>
        ))}
      </div>

      <div class="text-center">
        <a href="/industries/" class="text-[13.5px] text-cyan-500 font-medium hover:text-cyan-600">
          See all six industries we serve →
        </a>
      </div>
    </div>
  </section>

  {/* ==================================================== */}
  {/* SECTION 6 · QUESTIONS WE ANSWER                       */}
  {/* ==================================================== */}
  <section class="section">
    <div class="container-site">
      <SectionHeader
        eyebrow="QUESTIONS WE ANSWER"
        title="If you've asked any of these, AestheticIQ was built for you."
        subtitle="Every commercial, regulatory, and investment decision in UK aesthetics starts with a question about clinics, practitioners, or brands."
        centered
      />

      <div class="grid md:grid-cols-2 gap-3 max-w-[1000px] mx-auto">
        {questions.map((q, i) => (
          <div class="flex gap-4 items-start p-4 bg-slate-50 border border-slate-200 rounded-card">
            <span class="font-serif text-base text-cyan-500 leading-none flex-shrink-0 mt-1">
              {String(i + 1).padStart(2, '0')}
            </span>
            <span class="text-[13.5px] text-navy-700 leading-relaxed">{q}</span>
          </div>
        ))}
      </div>
    </div>
  </section>

  {/* ==================================================== */}
  {/* SECTION 7 · LATEST INSIGHTS (DYNAMIC)                */}
  {/* ==================================================== */}
  <section class="section-alt">
    <div class="container-site">
      <div class="flex justify-between items-end mb-10 flex-wrap gap-4">
        <div>
          <div class="eyebrow mb-3">LATEST FROM INSIGHTS</div>
          <h2 class="display-title">Market data. Regulatory commentary. Methodology.</h2>
        </div>
        <a href="/insights/" class="text-[13.5px] text-cyan-500 font-medium hover:text-cyan-600">
          All insights →
        </a>
      </div>

      <div class="grid md:grid-cols-3 gap-5">
        {insightsToShow.map((insight: any) => (
          <a
            href={`/insights/${insight.slug}/`}
            class="bg-white border border-slate-200 rounded-card overflow-hidden hover:border-cyan-500 hover:shadow-card-strong transition-all duration-200 flex flex-col cursor-pointer"
          >
            <div class="p-5">
              <span
                class:list={[
                  'inline-block text-[9.5px] tracking-eyebrow uppercase font-medium px-2.5 py-1 rounded-pill mb-3',
                  categoryStyles[insight.data.category] || categoryStyles['Methodology'],
                ]}
              >
                {insight.data.category}
              </span>

              <h3 class="font-serif text-lg text-navy-900 mb-2 leading-tight">
                {insight.data.title}
              </h3>

              <p class="text-[12.5px] text-slate-600 leading-relaxed mb-4">
                {insight.data.excerpt}
              </p>

              <div class="text-[10.5px] text-slate-400 flex gap-2 items-center mt-auto">
                <span class="text-navy-700 font-medium">{formatDate(insight.data.date)}</span>
                <span>·</span>
                <span>{insight.data.readTime}</span>
              </div>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  {/* ==================================================== */}
  {/* SECTION 8 · FINAL CTA                                 */}
  {/* ==================================================== */}
  <section class="bg-navy-900 text-white py-20 relative overflow-hidden">
    <div
      class="absolute -top-24 -right-24 w-[400px] h-[400px] rounded-full"
      style="background: rgba(0,180,216,0.05);"
    />
    <div class="container-site relative z-10">
      <div class="text-center max-w-[680px] mx-auto">
        <div class="text-[10px] tracking-eyebrow uppercase text-cyan-500 font-medium mb-4">
          GET STARTED
        </div>
        <h2 class="font-serif text-4xl leading-tight tracking-tighter mb-4">
          See your territory, your competitors, or your target list. In 20 minutes.
        </h2>
        <p class="text-[15px] text-white/70 leading-relaxed mb-8">
          Every demo is tailored. Tell us your market, your product, or your investment thesis.
          We'll show you what the platform sees.
        </p>
        <div class="flex gap-3 justify-center flex-wrap mb-4">
          <a href="/contact/" class="btn-primary">Book a demo →</a>
          <a href="/contact/" class="btn-secondary-light">Download sample dataset</a>
        </div>
        <div class="text-[11.5px] text-white/40">
          No sales pressure · 20-minute call · Sample data provided
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
