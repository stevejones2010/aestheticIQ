---
const currentYear = new Date().getFullYear();
---

<footer class="bg-[#05101c] text-white/55 pt-14 pb-8">
  <div class="container-site">
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-[2fr_1fr_1fr_1fr_1fr] gap-8 mb-10">
      <div>
        <div class="font-serif text-[1.3rem] text-white mb-3">
          Aesthetic<span class="text-cyan-500">IQ</span>
        </div>
        <p class="text-[13px] text-white/45 leading-relaxed max-w-[260px] mb-4">
          The UK aesthetic clinic intelligence platform. Purpose-built for the companies that sell into the UK aesthetic ecosystem.
        </p>
      </div>

      <div>
        <h5 class="text-[10px] uppercase tracking-eyebrow text-white font-medium mb-3">Solutions</h5>
        <a href="/solutions/reference-data/" class="block py-1 text-[12.5px] text-white/55 hover:text-cyan-500 transition-colors">Reference Data</a>
        <a href="/solutions/market-intelligence/" class="block py-1 text-[12.5px] text-white/55 hover:text-cyan-500 transition-colors">Market Intelligence</a>
        <a href="/solutions/marketing-services/" class="block py-1 text-[12.5px] text-white/55 hover:text-cyan-500 transition-colors">Marketing Services</a>
        <a href="/solutions/consultancy/" class="block py-1 text-[12.5px] text-white/55 hover:text-cyan-500 transition-colors">Consultancy</a>
        <a href="/solutions/compliance-pv/" class="block py-1 text-[12.5px] text-white/55 hover:text-cyan-500 transition-colors">Compliance &amp; PV</a>
      </div>

      <div>
        <h5 class="text-[10px] uppercase tracking-eyebrow text-white font-medium mb-3">Industries</h5>
        <a href="/industries/pharma/" class="block py-1 text-[12.5px] text-white/55 hover:text-cyan-500 transition-colors">Pharma &amp; Injectables</a>
        <a href="/industries/medical-devices/" class="block py-1 text-[12.5px] text-white/55 hover:text-cyan-500 transition-colors">Medical Devices</a>
        <a href="/industries/beauty-skincare/" class="block py-1 text-[12.5px] text-white/55 hover:text-cyan-500 transition-colors">Beauty &amp; Skincare</a>
        <a href="/industries/distributors/" class="block py-1 text-[12.5px] text-white/55 hover:text-cyan-500 transition-colors">Distributors</a>
        <a href="/industries/training/" class="block py-1 text-[12.5px] text-white/55 hover:text-cyan-500 transition-colors">Training Providers</a>
        <a href="/industries/investors/" class="block py-1 text-[12.5px] text-white/55 hover:text-cyan-500 transition-colors">Investors</a>
      </div>

      <div>
        <h5 class="text-[10px] uppercase tracking-eyebrow text-white font-medium mb-3">Company</h5>
        <a href="/about/" class="block py-1 text-[12.5px] text-white/55 hover:text-cyan-500 transition-colors">About</a>
        <a href="/platform/" class="block py-1 text-[12.5px] text-white/55 hover:text-cyan-500 transition-colors">Platform</a>
        <a href="/insights/" class="block py-1 text-[12.5px] text-white/55 hover:text-cyan-500 transition-colors">Insights</a>
        <a href="/contact/" class="block py-1 text-[12.5px] text-white/55 hover:text-cyan-500 transition-colors">Contact</a>
      </div>

      <div>
        <h5 class="text-[10px] uppercase tracking-eyebrow text-white font-medium mb-3">Also from us</h5>
        <a href="https://clinicscore.co.uk" class="block py-1 text-[12.5px] text-cyan-500 hover:text-cyan-400 transition-colors">ClinicScore →</a>
        <p class="text-[11px] text-white/35 mt-1 leading-relaxed">Our free clinic benchmarking tool</p>
      </div>
    </div>

    <div class="flex flex-wrap justify-between items-center gap-4 pt-8 border-t border-white/8 text-[11.5px] text-white/35">
      <div>© {currentYear} AestheticIQ Ltd · Registered in England &amp; Wales</div>
      <div class="flex gap-5">
        <a href="/legal/privacy/" class="hover:text-cyan-500 transition-colors">Privacy</a>
        <a href="/legal/terms/" class="hover:text-cyan-500 transition-colors">Terms</a>
        <a href="/legal/cookies/" class="hover:text-cyan-500 transition-colors">Cookies</a>
      </div>
    </div>
  </div>
</footer>
