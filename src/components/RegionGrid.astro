---
/**
 * RegionGrid — heat-shaded regional cell grid.
 *
 * Used for: Devices (regional clinic density), Training (regional practitioner
 * density), any "by region" display where some regions are visually highlighted.
 *
 * Each cell has:
 *   - Region name (small, top)
 *   - Numeric value (serif font, cyan, prominent)
 *   - Label below (clinics, practitioners, etc.)
 *   - Optional heat level: 'hot' (cyan tinted), 'med' (light cyan), default (slate)
 *
 * Example usage:
 *   <RegionGrid
 *     header="Addressable clinics by region"
 *     subheader="RF device category"
 *     cells={[
 *       { name: 'London', value: 612, label: 'clinics', heat: 'hot' },
 *       { name: 'South East', value: 287, label: 'clinics' },
 *       { name: 'NW England', value: 243, label: 'clinics' },
 *       { name: 'Midlands', value: 198, label: 'clinics', heat: 'med' },
 *     ]}
 *     footer="Stylised example · addressable = fit profile + GMC prescriber"
 *   />
 */

export interface RegionCell {
  name: string;
  value: string | number;
  label?: string;
  heat?: 'hot' | 'med';   // optional highlighting
}

export interface Props {
  header: string;
  subheader?: string;
  cells: RegionCell[];
  footer?: string;
  columns?: number;       // default 3
}

const { header, subheader, cells, footer, columns = 3 } = Astro.props;
---

<div class="bg-white border border-slate-200 rounded-card p-5 shadow-card-strong">
  {/* Header */}
  <div class="flex justify-between items-center pb-3 border-b border-slate-200 mb-4">
    <div class="text-[12px] font-medium text-navy-900">{header}</div>
    {subheader && (
      <div class="text-[10px] text-slate-400">{subheader}</div>
    )}
  </div>

  {/* Region grid */}
  <div
    class="grid gap-2"
    style={`grid-template-columns: repeat(${columns}, minmax(0, 1fr));`}
  >
    {cells.map((cell) => {
      // Inline styles for heat states - matches original wireframe exactly
      const cellStyle = cell.heat === 'hot'
        ? 'background: rgba(0,180,216,0.1); border: 0.5px solid rgba(0,180,216,0.3);'
        : cell.heat === 'med'
        ? 'background: rgba(0,180,216,0.04); border: 0.5px solid #e2e8f0;'
        : 'background: #f8fafc; border: 0.5px solid #e2e8f0;';

      const valColor = cell.heat === 'hot' ? '#0284a8' : '#00b4d8';

      return (
        <div
          class="rounded-lg text-center"
          style={`padding: 0.7rem 0.8rem; ${cellStyle}`}
        >
          <div class="text-navy-900 font-medium" style="font-size: 10.5px; margin-bottom: 3px;">
            {cell.name}
          </div>
          <div
            class="font-serif leading-none"
            style={`font-size: 1rem; color: ${valColor};`}
          >
            {cell.value}
          </div>
          {cell.label && (
            <div class="text-slate-400" style="font-size: 9px; margin-top: 2px;">
              {cell.label}
            </div>
          )}
        </div>
      );
    })}
  </div>

  {/* Footer */}
  {footer && (
    <div class="pt-3 mt-3 border-t border-slate-200 text-[10px] text-slate-400 text-center leading-relaxed italic">
      {footer}
    </div>
  )}
</div>
