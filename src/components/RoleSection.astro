---
export interface Props {
  badge: string;          // e.g. "Role 01 · Commercial"
  title: string;
  description: string;
  questions: string[];    // list of "Answers questions like..."
  outcomeLabel?: string;  // default "OUTCOME"
  outcome: string;        // can include HTML for the cross-sell links etc.
  reverse?: boolean;      // true = visual on left, content on right
  alt?: boolean;          // true = alt background (slate-50)
}

const {
  badge,
  title,
  description,
  questions,
  outcomeLabel = 'OUTCOME',
  outcome,
  reverse = false,
  alt = false,
} = Astro.props;
---

<section class:list={[
  'py-16 border-b border-slate-100',
  alt && 'bg-slate-50 border-b-0',
]}>
  <div class="container-site">
    <div class:list={[
      'grid lg:grid-cols-[1fr_1.15fr] gap-14 items-start',
      reverse && 'lg:[&>*:first-child]:order-2',
    ]}>
      <div>
        <span class="inline-block text-[10px] tracking-eyebrow uppercase text-cyan-500 bg-cyan-500/8 px-3 py-1 rounded-pill font-medium mb-5">
          {badge}
        </span>

        <h3 class="font-serif text-3xl text-navy-900 leading-tight mb-4 tracking-tighter">
          {title}
        </h3>

        <p class="text-[14.5px] text-slate-600 leading-relaxed mb-6" set:html={description} />

        <div class="mb-6">
          <div class="text-[9px] tracking-eyebrow uppercase text-slate-500 font-medium mb-3">
            ANSWERS QUESTIONS LIKE
          </div>
          <div class="flex flex-col gap-2">
            {questions.map((q, i) => (
              <div class="flex gap-3 items-start py-2.5 px-4 bg-white border border-slate-200 rounded-lg text-[13px] text-navy-700 leading-relaxed">
                <span class="font-serif text-base text-cyan-500 leading-none flex-shrink-0 mt-0.5">
                  {String(i + 1).padStart(2, '0')}
                </span>
                <span set:html={q} />
              </div>
            ))}
          </div>
        </div>

        <div class="p-4 bg-cyan-500/5 border-l-2 border-cyan-500 rounded-r-lg">
          <div class="text-[9px] tracking-eyebrow uppercase text-cyan-700 font-medium mb-1">
            {outcomeLabel}
          </div>
          <div class="text-[12.5px] text-navy-900 leading-relaxed" set:html={outcome} />
        </div>
      </div>

      <div class="lg:sticky lg:top-20">
        <slot />
      </div>
    </div>
  </div>
</section>
